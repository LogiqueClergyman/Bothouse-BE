DATABASE_URL=postgres://postgres:postgres@localhost:5432/bothouse
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_32_byte_hex_string_here_0000
JWT_EXPIRY_SECS=86400
REFRESH_TOKEN_EXPIRY_SECS=2592000
BCRYPT_COST=12

# ─── House Signing Key ────────────────────────────────────────────────────────
# 32-byte random hex — used to HMAC-sign game result hashes (chain-agnostic).
# This is NOT a wallet key. Generate with: openssl rand -hex 32
HOUSE_SIGNING_KEY=change_me_32_byte_hex_string_here_0001

TURN_TIMEOUT_MS=15000
RAKE_BPS=500
PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
BASE_URL=http://localhost:8080
TESTNET_BASE_URL=http://localhost:8080

# ─── Chain Selection ──────────────────────────────────────────────────────────
# "evm" or "onechain"
CHAIN_TYPE=onechain

# ─── OneChain (Sui-based) ─────────────────────────────────────────────────────
# RPC endpoint for the OneChain network
SETTLEMENT_RPC_URL=https://rpc.onechain.dev
# Ed25519 private key (32-byte hex, 0x-prefixed) of the house settler wallet.
# This wallet pays gas and calls the Move escrow contract to settle games.
SETTLEMENT_PRIVATE_KEY=0x_your_ed25519_settler_key_hex_64_chars
# Move package ID of the deployed escrow contract (0x-prefixed object ID)
ESCROW_CONTRACT_ADDRESS=0x_your_move_package_id
# Sui-format address that receives the rake on every settlement
HOUSE_WALLET_ADDRESS=0x_your_house_wallet_sui_address
# CHAIN_ID is not used for OneChain — omit or leave blank
CHAIN_ID=

# ─── EVM (uncomment if using CHAIN_TYPE=evm instead) ─────────────────────────
# SETTLEMENT_RPC_URL=https://sepolia.base.org
# SETTLEMENT_PRIVATE_KEY=0x_your_secp256k1_settler_key
# ESCROW_CONTRACT_ADDRESS=0x_your_solidity_contract_address
# HOUSE_WALLET_ADDRESS=0x_your_evm_house_wallet
# CHAIN_ID=84532
